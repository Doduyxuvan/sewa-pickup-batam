generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id           String   @id @default(cuid())
  orderNumber  String   @unique
  customerName String
  phone        String
  origin       String
  destination  String
  itemDesc     String
  weight       Float?
  vehicleType  String   @default("pickup")
  status       String   @default("pending")
  notes        String?
  totalPrice   Float?
  photos       Photo[]
  reviews      Review[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Photo {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  url       String
  publicId  String?
  type      String   @default("pickup")
  caption   String?
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])
  name      String
  rating    Int
  comment   String
  service   String?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Service {
  id          String  @id @default(cuid())
  name        String
  description String
  basePrice   Float
  pricePerKm  Float
  icon        String?
  isActive    Boolean @default(true)
}